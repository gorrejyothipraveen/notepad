<!DOCTYPE html>
<html lang="en">

<head>
  <title>note</title>
</head>

<body>
  <main>
    <form action="/edit_note" method="post">
      <section>
        <label for="note">Note : </label>
        <textarea name="note" id="" cols="100" rows="50"><%= it.note %></textarea>
      </section>
      <button type="submit">send</button>
    </form>
  </main>
</body>

</html>